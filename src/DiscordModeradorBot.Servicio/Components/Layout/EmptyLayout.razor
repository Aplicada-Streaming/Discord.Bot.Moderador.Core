@inherits LayoutComponentBase

@* Layout sin barra lateral para las pantallas de autenticación (wireframes-primer-ingreso:
   tarjeta centrada, sin sidebar hasta abrir sesión). Provee los proveedores de MudBlazor
   por si las páginas de auth usan componentes Mud. *@

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<main class="auth-page">
    @Body
</main>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

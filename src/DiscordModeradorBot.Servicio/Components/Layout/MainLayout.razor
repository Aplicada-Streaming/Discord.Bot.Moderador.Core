@inherits LayoutComponentBase

@* El tema (solo estilos) funciona en SSR; los proveedores de diálogo/snackbar/popover se montan en
   un componente interactivo (ProveedoresMud, @rendermode InteractiveServer) para que los diálogos
   disparados por las páginas interactivas del panel funcionen (p. ej. desbaneo, CU-07). *@
<MudThemeProvider />
<ProveedoresMud />

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@page "/ingresar"
@using DiscordModeradorBot.Servicio.Aplicacion
@inject ServicioAdministrador ServicioAdministrador
@inject NavigationManager Navegacion
@layout EmptyLayout

@* Autenticación del administrador (CU-09, RN-12, wireframes-primer-ingreso, variante B). Página
   de render estático (SSR): el formulario postea al endpoint /api/auth/ingresar, que verifica
   las credenciales y emite la cookie de sesión. Sin cuenta creada se redirige al primer ingreso
   (CU-09 CA-04, AUTH_SIN_CUENTA). *@

<PageTitle>Iniciar sesión</PageTitle>

<div class="auth-card">
    <h1>Iniciar sesión</h1>

    @if (_creado)
    {
        <div class="auth-ok" role="status">Cuenta creada. Ingresá con tus credenciales.</div>
    }

    @if (_mensajeError is not null)
    {
        <div class="auth-error" role="alert">@_mensajeError</div>
    }

    @* data-enhance="false": el panel corre con interactividad global (InteractiveServer) para los
       diálogos de MudBlazor, pero este formulario debe postear como navegación HTML real (no por la
       navegación mejorada de Blazor) para que el endpoint SSR emita la cookie y el redirect con el
       código de resultado (CU-09). *@
    <form method="post" action="/api/auth/ingresar" data-enhance="false">
        @* Token antiforgery validado en el endpoint (protección CSRF, endurecimiento de seguridad). *@
        <AntiforgeryToken />
        <label for="usuario">Identificador</label>
        <input id="usuario" name="usuario" type="text" autocomplete="username" required />

        <label for="contrasena">Contraseña</label>
        <input id="contrasena" name="contrasena" type="password" autocomplete="current-password" required />

        <button type="submit">Iniciar sesión</button>
    </form>
</div>

@* Versión de build (inyectada por el pipeline vía la variable de entorno BUILD_VERSION del
   contenedor). Sirve para identificar qué imagen está corriendo al diagnosticar despliegues. *@
<div class="auth-version">v@_versionBuild</div>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? CodigoError { get; set; }

    [SupplyParameterFromQuery(Name = "creado")]
    private string? Creado { get; set; }

    private string? _mensajeError;
    private bool _creado;

    // Versión de build inyectada por el pipeline (variable de entorno BUILD_VERSION del contenedor).
    // Si no está definida (ejecución local sin el arg), muestra "dev".
    private string _versionBuild = Environment.GetEnvironmentVariable("BUILD_VERSION") ?? "dev";

    protected override async Task OnInitializedAsync()
    {
        // Sin cuenta: se redirige al primer ingreso (CU-09 CA-04, AUTH_SIN_CUENTA).
        if (!await ServicioAdministrador.ExisteAdministradorAsync())
        {
            Navegacion.NavigateTo("/configuracion-inicial", forceLoad: false, replace: true);
            return;
        }

        _creado = Creado == "1";

        // Mensajes neutros, sin enumeración de cuentas (CU-09 CA-02). El bloqueo por demasiados
        // intentos no distingue si el usuario existe (CU-09 §6, AUTH_DEMASIADOS_INTENTOS).
        _mensajeError = CodigoError switch
        {
            "AUTH_CREDENCIALES_INVALIDAS" =>
                "Credenciales inválidas. Verificá el identificador y la contraseña.",
            "AUTH_DEMASIADOS_INTENTOS" =>
                "Demasiados intentos fallidos. Esperá unos minutos antes de volver a intentarlo.",
            "ANTIFORGERY" =>
                "La sesión del formulario expiró. Volvé a intentarlo.",
            _ => null,
        };
    }
}

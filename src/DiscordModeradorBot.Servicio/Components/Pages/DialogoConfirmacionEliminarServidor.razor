@* Diálogo de confirmación de la baja de un servidor (CU-10). Es una acción destructiva: requiere
   confirmación explícita y advierte qué se elimina (la configuración) y qué se conserva (los
   incidentes, como historial de auditoría, RN-11). *@

<MudDialog>
    <DialogContent>
        <MudText>
            ¿Eliminar el servidor <b>@Servidor</b>?
        </MudText>
        <MudText Class="mt-2">
            Se eliminará el servidor junto con su configuración: reglas de contenido, exenciones,
            grupos de reglas y eventos. Los <b>incidentes</b> registrados se conservan como historial.
        </MudText>
        <MudText Class="mt-2">Esta acción no se puede deshacer.</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="Confirmar">Eliminar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string Servidor { get; set; } = string.Empty;

    private void Confirmar() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancelar() => MudDialog.Cancel();
}

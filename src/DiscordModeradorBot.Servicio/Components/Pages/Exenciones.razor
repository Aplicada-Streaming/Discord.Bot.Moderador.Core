@page "/exenciones"
@using DiscordModeradorBot.Servicio.Aplicacion
@using DiscordModeradorBot.Servicio.Aplicacion.Puertos
@using DiscordModeradorBot.Servicio.Dominio
@using DiscordModeradorBot.Servicio.Dominio.Exenciones
@attribute [Authorize]
@rendermode InteractiveServer
@inject ServicioExenciones ServicioExenciones
@inject IRepositorioServidores RepositorioServidores
@inject ISnackbar Snackbar

@* Definición de exenciones por rol, usuario o canal de confianza (CU-15, RN-07, RN-12). Solo el
   administrador autenticado ([Authorize], RN-12). Permite elegir un servidor registrado, agregar
   una exención (tipo + identificador snowflake, validado al guardar, RN-08), listarlas y quitarlas
   (CU-15 §5.A). El descarte previo de los exentos lo aplica el motor en el pipeline (RN-07). *@

<PageTitle>Exenciones</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Exenciones de confianza</MudText>

<MudText Class="mb-4">
    Los sujetos exentos —por rol, por usuario o por canal de confianza— quedan fuera de la
    moderación: se descartan antes de evaluar cualquier regla (RN-07).
</MudText>

@if (_servidores is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_servidores.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        No hay servidores registrados. Registrá un servidor antes de definir exenciones (CU-10).
    </MudAlert>
}
else
{
    <MudSelect T="string" Label="Servidor" Value="_servidorId" ValueChanged="CambiarServidorAsync"
               Class="mb-4" Dense="true">
        @foreach (var servidor in _servidores)
        {
            <MudSelectItem T="string" Value="@servidor.SnowflakeServidor.Valor">
                @(servidor.NombreDescriptivo ?? servidor.SnowflakeServidor.Valor)
                (@servidor.SnowflakeServidor.Valor)
            </MudSelectItem>
        }
    </MudSelect>

    @if (_servidorId is not null)
    {
        <MudPaper Class="pa-4 mb-4">
            <MudText Typo="Typo.h6" Class="mb-2">Agregar exención</MudText>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudSelect T="TipoSujetoExento" @bind-Value="_tipo" Label="Tipo" Dense="true">
                        <MudSelectItem T="TipoSujetoExento" Value="TipoSujetoExento.Rol">Rol</MudSelectItem>
                        <MudSelectItem T="TipoSujetoExento" Value="TipoSujetoExento.Usuario">Usuario</MudSelectItem>
                        <MudSelectItem T="TipoSujetoExento" Value="TipoSujetoExento.Canal">Canal</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="5">
                    <MudTextField @bind-Value="_identificador" Label="Identificador (snowflake)"
                                  Placeholder="solo dígitos" Immediate="true" />
                </MudItem>
                <MudItem xs="12" sm="3" Class="d-flex align-center">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                               OnClick="AgregarAsync" Disabled="_procesando">Agregar</MudButton>
                </MudItem>
            </MudGrid>
        </MudPaper>

        @if (_exenciones is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else if (_exenciones.Count == 0)
        {
            <MudAlert Severity="Severity.Info">
                Este servidor no tiene exenciones declaradas.
            </MudAlert>
        }
        else
        {
            <MudTable Items="_exenciones" Hover="true" Dense="true" T="Exencion">
                <HeaderContent>
                    <MudTh>Tipo</MudTh>
                    <MudTh>Identificador</MudTh>
                    <MudTh></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="Tipo">@context.Tipo</MudTd>
                    <MudTd DataLabel="Identificador">@context.Sujeto.Valor</MudTd>
                    <MudTd>
                        <MudButton Color="Color.Error" Size="Size.Small" Variant="Variant.Text"
                                   OnClick="@(() => QuitarAsync(context))" Disabled="_procesando">
                            Quitar
                        </MudButton>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    }
}

@code {
    private IReadOnlyList<DiscordModeradorBot.Servicio.Dominio.Servidores.ServidorRegistrado>? _servidores;
    private IReadOnlyList<Exencion>? _exenciones;
    private string? _servidorId;
    private TipoSujetoExento _tipo = TipoSujetoExento.Rol;
    private string _identificador = string.Empty;
    private bool _procesando;

    protected override async Task OnInitializedAsync()
    {
        _servidores = await RepositorioServidores.ListarAsync();
        if (_servidores.Count > 0)
        {
            await CambiarServidorAsync(_servidores[0].SnowflakeServidor.Valor);
        }
    }

    private async Task CambiarServidorAsync(string servidorId)
    {
        _servidorId = servidorId;
        await RecargarAsync();
    }

    private async Task RecargarAsync()
    {
        if (_servidorId is null)
        {
            return;
        }

        _exenciones = await ServicioExenciones.ListarAsync(new Snowflake(_servidorId));
    }

    private async Task AgregarAsync()
    {
        if (_servidorId is null)
        {
            return;
        }

        _procesando = true;
        var resultado = await ServicioExenciones.AgregarAsync(
            new Snowflake(_servidorId), _tipo, _identificador);

        if (resultado.Exito)
        {
            Snackbar.Add("Exención agregada; el sujeto queda fuera de la moderación (RN-07).", Severity.Success);
            _identificador = string.Empty;
            await RecargarAsync();
        }
        else
        {
            // Códigos del CU-15: identificador inválido (RN-08) o duplicado.
            var severidad = resultado.Codigo == ServicioExenciones.CodigoDuplicada
                ? Severity.Warning
                : Severity.Error;
            Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", severidad);
        }

        _procesando = false;
    }

    private async Task QuitarAsync(Exencion exencion)
    {
        if (_servidorId is null)
        {
            return;
        }

        _procesando = true;
        var quitada = await ServicioExenciones.QuitarAsync(new Snowflake(_servidorId), exencion);
        Snackbar.Add(
            quitada
                ? "Exención quitada; el sujeto vuelve a estar sujeto a la moderación (CU-15)."
                : "La exención ya no existía.",
            quitada ? Severity.Success : Severity.Info);
        await RecargarAsync();
        _procesando = false;
    }
}

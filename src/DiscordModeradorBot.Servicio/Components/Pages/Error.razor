@page "/Error"
@using System.Diagnostics
@layout EmptyLayout

@* Página de error genérica (servida por UseExceptionHandler fuera de Development). SSR sobre
   EmptyLayout, sin circuito; tarjeta centrada coherente con el tema. No revela detalles sensibles. *@

<PageTitle>Error</PageTitle>

<MudPaper Class="auth-card mx-auto mt-16 pa-8" Elevation="0" Outlined="true" MaxWidth="420px">
    <MudText Typo="Typo.h6" Color="Color.Error" GutterBottom="true">Ocurrió un error</MudText>
    <MudText Typo="Typo.body2" Class="mb-4">
        No pudimos procesar tu solicitud. Reintentá la acción; si el problema persiste, recargá la página.
    </MudText>

    @if (ShowRequestId)
    {
        <MudText Typo="Typo.caption" Class="mud-text-secondary mb-4">
            Identificador de solicitud: <code>@RequestId</code>
        </MudText>
    }

    <MudButton Href="/incidentes" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.ArrowBack">
        Volver al panel
    </MudButton>
</MudPaper>

@code {
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}

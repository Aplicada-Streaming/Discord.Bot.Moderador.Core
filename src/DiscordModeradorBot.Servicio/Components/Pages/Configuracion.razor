@page "/configuracion"
@using DiscordModeradorBot.Servicio.Aplicacion
@using DiscordModeradorBot.Servicio.Aplicacion.Puertos
@using DiscordModeradorBot.Servicio.Dominio
@using DiscordModeradorBot.Servicio.Dominio.Configuracion
@using DiscordModeradorBot.Servicio.Dominio.Moderacion.Reglas
@attribute [Authorize]
@rendermode InteractiveServer
@inject ServicioConfiguracionModeracion ServicioConfiguracion
@inject ServicioRegistroReglaContenido ServicioReglas
@inject IRepositorioServidores RepositorioServidores
@inject ISnackbar Snackbar

@* Administración de la configuración de moderación dirigida por descriptores (CU-11, RN-10,
   ADR-12). Solo el administrador autenticado ([Authorize], RN-12). Permite administrar reglas de
   contenido, grupos de reglas con su modo de coincidencia (RN-15) y eventos/políticas con sus
   grupos y prioridad (RN-04). Cada parámetro configurable se renderiza desde su DescriptorParametro
   (etiqueta, leyenda, default, límites, ejemplos) con ayuda contextual; la validación toma los
   límites del descriptor (no hardcodea). La UI propone, el humano confirma, el sistema valida; la
   ranura del asistente de IA queda reservada y deshabilitada (forward-compat, no se construye). *@

<PageTitle>Configuración de moderación</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Configuración de moderación</MudText>
<MudText Class="mb-4">
    Reglas, grupos y eventos dirigidos por descriptores: cada parámetro toma su valor por defecto,
    sus límites y su ayuda del descriptor único (RN-10, ADR-12).
</MudText>

@if (_servidores is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_servidores.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        No hay servidores registrados. Registrá un servidor antes de configurar la moderación
        (<MudLink Href="/servidores">Registro y prueba</MudLink>).
    </MudAlert>
}
else
{
    <MudSelect T="string" Label="Servidor" Value="_servidorId" ValueChanged="CambiarServidorAsync"
               Class="mb-4" Dense="true">
        @foreach (var servidor in _servidores)
        {
            <MudSelectItem T="string" Value="@servidor.SnowflakeServidor.Valor">
                @(servidor.NombreDescriptivo ?? servidor.SnowflakeServidor.Valor)
            </MudSelectItem>
        }
    </MudSelect>

    @if (_servidorId is not null)
    {
        <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">

            @* ---- Reglas de contenido ---- *@
            <MudTabPanel Text="Reglas">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Nueva regla de contenido</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_reglaNombre" Label="Nombre" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_reglaPatron" Label="Patrón (expresión regular)"
                                          HelperText="Se valida al guardar (RN-03)." />
                        </MudItem>
                        <MudItem xs="12" sm="2" Class="d-flex align-center">
                            <MudButton Color="Color.Primary" Variant="Variant.Filled"
                                       OnClick="GuardarReglaAsync" Disabled="_procesando">Guardar</MudButton>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudTabPanel>

            @* ---- Grupos de reglas ---- *@
            <MudTabPanel Text="Grupos">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Nuevo grupo de reglas</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_grupoNombre" Label="Nombre" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="ModoCoincidencia" @bind-Value="_grupoModo" Label="Modo de coincidencia"
                                       HelperText="Cómo se combinan las reglas del grupo (RN-15).">
                                <MudSelectItem T="ModoCoincidencia" Value="ModoCoincidencia.Todas">Todas las reglas coinciden</MudSelectItem>
                                <MudSelectItem T="ModoCoincidencia" Value="ModoCoincidencia.Alguna">Al menos una coincide</MudSelectItem>
                                <MudSelectItem T="ModoCoincidencia" Value="ModoCoincidencia.AlMenosN">Al menos N coinciden</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        @if (_grupoModo == ModoCoincidencia.AlMenosN)
                        {
                            <MudItem xs="12" sm="4">
                                <MudNumericField T="int" @bind-Value="_grupoN" Label="N mínimo" Min="1" />
                            </MudItem>
                        }
                    </MudGrid>
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Reglas del grupo</MudText>
                    @if (_reglasDisponibles.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">
                            Cargá al menos una regla de contenido antes de armar un grupo (RC-04).
                        </MudAlert>
                    }
                    else
                    {
                        @foreach (var regla in _reglasDisponibles)
                        {
                            <MudCheckBox T="bool" Value="@_reglasSeleccionadas.Contains(regla.Id)"
                                         ValueChanged="@(v => AlternarRegla(regla.Id, v))"
                                         Label="@($"{regla.Nombre} (contenido)")" Dense="true" />
                        }
                        <MudCheckBox T="bool" Value="_incluirConducta"
                                     ValueChanged="@(v => _incluirConducta = v)"
                                     Label="Ráfaga distribuida (conducta)" Dense="true" />
                    }
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mt-2"
                               OnClick="GuardarGrupoAsync" Disabled="_procesando">Guardar grupo</MudButton>
                </MudPaper>

                @if (_grupos is not null && _grupos.Count > 0)
                {
                    <MudTable Items="_grupos" Hover="true" Dense="true" T="GrupoPersistido">
                        <HeaderContent>
                            <MudTh>Nombre</MudTh><MudTh>Modo</MudTh><MudTh>Reglas</MudTh><MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Nombre">@context.Nombre</MudTd>
                            <MudTd DataLabel="Modo">@context.ModoCoincidencia @(context.MinimoCoincidencias is { } n ? $"({n})" : "")</MudTd>
                            <MudTd DataLabel="Reglas">@context.Reglas.Count</MudTd>
                            <MudTd>
                                <MudButton Color="Color.Error" Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => EliminarGrupoAsync(context.Id))" Disabled="_procesando">
                                    Eliminar
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            @* ---- Eventos / políticas ---- *@
            <MudTabPanel Text="Eventos">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">Nuevo evento</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_eventoNombre" Label="Nombre" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudNumericField T="int" @bind-Value="_eventoPrioridad" Label="Prioridad"
                                             HelperText="Menor = mayor prioridad (RN-04)." />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="bool" @bind-Value="_eventoSimulacion" Label="Modo">
                                <MudSelectItem T="bool" Value="true">Simulación</MudSelectItem>
                                <MudSelectItem T="bool" Value="false">Ejecución real</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                    @if (_eventoSimulacion)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="mt-2">Modo simulación</MudChip>
                    }
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Grupos del evento</MudText>
                    @if (_grupos is null || _grupos.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">Creá al menos un grupo (RN-15).</MudAlert>
                    }
                    else
                    {
                        @foreach (var grupo in _grupos)
                        {
                            <MudCheckBox T="bool" Value="@_gruposEventoSeleccionados.Contains(grupo.Id)"
                                         ValueChanged="@(v => AlternarGrupoEvento(grupo.Id, v))"
                                         Label="@grupo.Nombre" Dense="true" />
                        }
                    }
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mt-2"
                               OnClick="GuardarEventoAsync" Disabled="_procesando">Guardar evento</MudButton>
                </MudPaper>

                @if (_eventos is not null && _eventos.Count > 0)
                {
                    <MudTable Items="_eventos" Hover="true" Dense="true" T="EventoPersistido">
                        <HeaderContent>
                            <MudTh>Nombre</MudTh><MudTh>Prioridad</MudTh><MudTh>Modo</MudTh><MudTh>Grupos</MudTh><MudTh>Acciones</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Nombre">@context.Nombre</MudTd>
                            <MudTd DataLabel="Prioridad">@context.Prioridad</MudTd>
                            <MudTd DataLabel="Modo">@context.Modo</MudTd>
                            <MudTd DataLabel="Grupos">@context.GruposIds.Count</MudTd>
                            <MudTd DataLabel="Acciones">@context.Acciones.Count</MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            @* ---- Parámetros dirigidos por descriptor (RN-10, ADR-12, design-rules-config-esquema) ---- *@
            <MudTabPanel Text="Parámetros">
                <div class="d-flex align-center justify-space-between flex-wrap ga-2 mb-2">
                    <MudText Typo="Typo.h6">Parámetros de detección dirigidos por descriptor</MudText>
                    @* Indicador de modo simulación (§4.6): color + etiqueta, nunca solo color. *@
                    @if (_paramSimulacion)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                                 Icon="@Icons.Material.Filled.Science">Modo simulación</MudChip>
                    }
                </div>
                <MudText Class="mb-3">
                    Cada campo toma su etiqueta, su valor por defecto, sus límites y su ayuda del
                    descriptor único; la validación usa esos límites (RN-10, ADR-12). La UI propone, el
                    humano confirma, el sistema valida.
                </MudText>

                @* Presets / recetas (§4.4): cargan un conjunto de valores sugeridos del descriptor; no
                   se aplican directo, aterrizan en simulación para previsualizar antes de confirmar. *@
                <MudText Typo="Typo.subtitle2" Class="mb-1">Presets sugeridos</MudText>
                <div class="d-flex flex-wrap ga-2 mb-3">
                    @foreach (var preset in _presets)
                    {
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Tune"
                                   OnClick="@(() => AplicarPreset(preset))">@preset.Nombre</MudButton>
                    }
                </div>

                @* Campo numérico dirigido por descriptor (§4.1): valor inicial = default; hint con
                   default y límites; validación inline desde los límites; ayuda contextual asociada. *@
                <MudNumericField T="int" Label="@RegistroDescriptores.UmbralCanalesDistintos.Etiqueta"
                                 @bind-Value="_umbralCanales"
                                 Min="@RegistroDescriptores.UmbralCanalesDistintos.Minimo"
                                 Max="@RegistroDescriptores.UmbralCanalesDistintos.Maximo"
                                 Validation="@((Func<int, string?>)ValidarUmbralCanales)"
                                 HelperText="@HintDe(RegistroDescriptores.UmbralCanalesDistintos)"
                                 Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Info"
                                 OnAdornmentClick="@(() => AlternarAyuda(RegistroDescriptores.UmbralCanalesDistintos.Clave))"
                                 aria-describedby="ayuda-umbral-canales-distintos"
                                 Class="mb-1" />
                @if (_ayudaAbierta.Contains(RegistroDescriptores.UmbralCanalesDistintos.Clave))
                {
                    @AyudaContextual(RegistroDescriptores.UmbralCanalesDistintos)
                }

                <MudNumericField T="double" Label="@RegistroDescriptores.VentanaDeteccionSegundos.Etiqueta"
                                 @bind-Value="_ventanaDeteccion" Step="0.5"
                                 Min="@RegistroDescriptores.VentanaDeteccionSegundos.Minimo"
                                 Max="@RegistroDescriptores.VentanaDeteccionSegundos.Maximo"
                                 Validation="@((Func<double, string?>)ValidarVentanaDeteccion)"
                                 HelperText="@HintDe(RegistroDescriptores.VentanaDeteccionSegundos)"
                                 Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Info"
                                 OnAdornmentClick="@(() => AlternarAyuda(RegistroDescriptores.VentanaDeteccionSegundos.Clave))"
                                 aria-describedby="ayuda-ventana-deteccion"
                                 Class="mt-3 mb-1" />
                @if (_ayudaAbierta.Contains(RegistroDescriptores.VentanaDeteccionSegundos.Clave))
                {
                    @AyudaContextual(RegistroDescriptores.VentanaDeteccionSegundos)
                }

                <MudNumericField T="double" Label="@RegistroDescriptores.VentanaAntirreboteSegundos.Etiqueta"
                                 @bind-Value="_ventanaAntirrebote" Step="0.5"
                                 Min="@RegistroDescriptores.VentanaAntirreboteSegundos.Minimo"
                                 Max="@RegistroDescriptores.VentanaAntirreboteSegundos.Maximo"
                                 Validation="@((Func<double, string?>)ValidarVentanaAntirrebote)"
                                 HelperText="@HintDe(RegistroDescriptores.VentanaAntirreboteSegundos)"
                                 Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Info"
                                 OnAdornmentClick="@(() => AlternarAyuda(RegistroDescriptores.VentanaAntirreboteSegundos.Clave))"
                                 aria-describedby="ayuda-ventana-antirrebote"
                                 Class="mt-3 mb-1" />
                @if (_ayudaAbierta.Contains(RegistroDescriptores.VentanaAntirreboteSegundos.Clave))
                {
                    @AyudaContextual(RegistroDescriptores.VentanaAntirreboteSegundos)
                }

                @* Previsualización: explicación EN PALABRAS generada por ExplicadorEnPalabras a partir
                   de descriptores + valores (§4.5); se regenera al cambiar un valor, no se redacta a
                   mano. Es también el texto de previsualización de la propuesta antes de confirmar. *@
                <MudPaper Class="pa-3 my-4" Outlined="true" Style="border-left: 4px solid var(--mud-palette-primary);">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Explicación en palabras (previsualización)</MudText>
                    <MudText Typo="Typo.body2" id="explicacion-en-palabras">@ExplicacionEnPalabras</MudText>
                </MudPaper>

                @* Modo simulación + confirmación: la UI NO aplica directo (§6, human-in-the-loop). *@
                <MudSwitch T="bool" @bind-Value="_paramSimulacion" Color="Color.Warning"
                           Label="Dejar la política en modo simulación (no ejecuta acciones reales)" />
                <div class="mt-2">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="ConfirmarParametros" Disabled="@(_procesando || !ParametrosValidos)">
                        Confirmar configuración
                    </MudButton>
                </div>

                @* Ranura del asistente de IA, RESERVADA y deshabilitada (forward-compat, §4.7). *@
                <MudPaper Class="pa-4 mt-4" Outlined="true" Style="border-style: dashed;"
                          aria-disabled="true"
                          aria-label="Asistente de configuración con IA, deshabilitado, próximamente">
                    <div class="d-flex align-center ga-2">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Default" />
                        <MudText Typo="Typo.subtitle2">Asistente de configuración (IA)</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Disabled="true">próximamente</MudChip>
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">
                        Próximamente: el asistente propondrá una configuración (una propuesta validable),
                        el humano la confirma y el sistema la valida contra los descriptores. Ranura
                        reservada; no disponible en esta versión.
                    </MudText>
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    }
}

@* Tarjeta de ayuda contextual (§4.2): título "¿qué es <parámetro>?", leyenda y ejemplos del
   descriptor (nunca escritos a mano). Se asocia al campo por id (aria-describedby) para que el lector
   de pantalla la anuncie con el control. Genérica sobre el tipo del descriptor (int/double). *@
@{
    RenderFragment AyudaContextual<T>(DescriptorParametro<T> d) where T : struct, IComparable<T> =>
        @<MudAlert Severity="Severity.Info" Dense="true" Class="mb-2" id="@($"ayuda-{d.Clave}")">
            <MudText Typo="Typo.subtitle2">¿Qué es @d.Etiqueta?</MudText>
            <MudText Typo="Typo.body2" Class="mb-1">@d.Leyenda</MudText>
            <MudText Typo="Typo.caption">
                Por defecto @d.ValorPorDefecto; entre @d.Minimo y @d.Maximo.
                Ejemplos: @string.Join(", ", d.Ejemplos.Select(e => e.ToString())).
            </MudText>
        </MudAlert>;
}

@code {
    private sealed record ReglaItem(int Id, string Nombre);

    /// <summary>Preset/receta (§4.4): un conjunto coherente de valores sugeridos para los descriptores.</summary>
    private sealed record Preset(string Nombre, int UmbralCanales, double VentanaDeteccion, double VentanaAntirrebote);

    private IReadOnlyList<DiscordModeradorBot.Servicio.Dominio.Servidores.ServidorRegistrado>? _servidores;
    private string? _servidorId;
    private bool _procesando;

    // Reglas
    private string _reglaNombre = string.Empty;
    private string _reglaPatron = string.Empty;
    private List<ReglaItem> _reglasDisponibles = new();

    // Grupos
    private string _grupoNombre = string.Empty;
    private ModoCoincidencia _grupoModo = ModoCoincidencia.Alguna;
    private int _grupoN = 2;
    private readonly HashSet<int> _reglasSeleccionadas = new();
    private bool _incluirConducta;
    private IReadOnlyList<GrupoPersistido>? _grupos;

    // Eventos
    private string _eventoNombre = string.Empty;
    private int _eventoPrioridad;
    private bool _eventoSimulacion = true;
    private readonly HashSet<int> _gruposEventoSeleccionados = new();
    private IReadOnlyList<EventoPersistido>? _eventos;

    // ---- Parámetros dirigidos por descriptor (CU-11, RN-10) ----
    // Valor inicial = el default del descriptor (NO hardcodeado en la pantalla; §1, anti-patrón §10).
    private int _umbralCanales = RegistroDescriptores.UmbralCanalesDistintos.ValorPorDefecto;
    private double _ventanaDeteccion = RegistroDescriptores.VentanaDeteccionSegundos.ValorPorDefecto;
    private double _ventanaAntirrebote = RegistroDescriptores.VentanaAntirreboteSegundos.ValorPorDefecto;
    private bool _paramSimulacion = true;
    private readonly HashSet<string> _ayudaAbierta = new();

    // Presets sugeridos: valores tomados de los ejemplos de cada descriptor (§4.4); no se hardcodean
    // a ojo, son combinaciones de los ejemplos declarados en el RegistroDescriptores.
    private readonly List<Preset> _presets = new()
    {
        new Preset("Sensible",
            RegistroDescriptores.UmbralCanalesDistintos.Ejemplos[0],
            RegistroDescriptores.VentanaDeteccionSegundos.Ejemplos[0],
            RegistroDescriptores.VentanaAntirreboteSegundos.Ejemplos[0]),
        new Preset("Equilibrado",
            RegistroDescriptores.UmbralCanalesDistintos.ValorPorDefecto,
            RegistroDescriptores.VentanaDeteccionSegundos.ValorPorDefecto,
            RegistroDescriptores.VentanaAntirreboteSegundos.ValorPorDefecto),
        new Preset("Tolerante",
            RegistroDescriptores.UmbralCanalesDistintos.Ejemplos[^1],
            RegistroDescriptores.VentanaDeteccionSegundos.Ejemplos[^1],
            RegistroDescriptores.VentanaAntirreboteSegundos.Ejemplos[^1]),
    };

    /// <summary>Hint del campo: default y límites del descriptor (§4.1), tomados, no escritos a mano.</summary>
    private static string HintDe<T>(DescriptorParametro<T> d) where T : struct, IComparable<T> =>
        $"Por defecto {d.ValorPorDefecto}; entre {d.Minimo} y {d.Maximo}.";

    /// <summary>Abre o cierra la ayuda contextual del campo (disclosure por teclado/ratón, §8).</summary>
    private void AlternarAyuda(string clave)
    {
        if (!_ayudaAbierta.Add(clave))
        {
            _ayudaAbierta.Remove(clave);
        }
    }

    /// <summary>Carga un preset en simulación: precarga los valores y deja la red de seguridad (§4.4).</summary>
    private void AplicarPreset(Preset preset)
    {
        _umbralCanales = preset.UmbralCanales;
        _ventanaDeteccion = preset.VentanaDeteccion;
        _ventanaAntirrebote = preset.VentanaAntirrebote;
        _paramSimulacion = true;
        Snackbar.Add($"Preset '{preset.Nombre}' cargado en simulación; previsualizá y confirmá.", Severity.Info);
    }

    // Validación inline DESDE los límites del descriptor (RN-10): el mensaje indica el rango admitido,
    // no solo "valor inválido" (§5, §8). No duplica reglas: usa el servicio de aplicación.
    private string? ValidarUmbralCanales(int valor)
    {
        var r = ServicioConfiguracionModeracion.ValidarEntero(RegistroDescriptores.UmbralCanalesDistintos, valor);
        return r.Valido ? null : r.Mensaje;
    }

    private string? ValidarVentanaDeteccion(double valor)
    {
        var r = ServicioConfiguracionModeracion.ValidarDecimal(RegistroDescriptores.VentanaDeteccionSegundos, valor);
        return r.Valido ? null : r.Mensaje;
    }

    private string? ValidarVentanaAntirrebote(double valor)
    {
        var r = ServicioConfiguracionModeracion.ValidarDecimal(RegistroDescriptores.VentanaAntirreboteSegundos, valor);
        return r.Valido ? null : r.Mensaje;
    }

    /// <summary>Todos los parámetros caen dentro de sus límites; condición para confirmar (§6).</summary>
    private bool ParametrosValidos =>
        RegistroDescriptores.UmbralCanalesDistintos.EsValido(_umbralCanales)
        && RegistroDescriptores.VentanaDeteccionSegundos.EsValido(_ventanaDeteccion)
        && RegistroDescriptores.VentanaAntirreboteSegundos.EsValido(_ventanaAntirrebote);

    /// <summary>
    /// Explicación EN PALABRAS de la configuración actual, generada por ExplicadorEnPalabras a partir
    /// de descriptores + valores (§4.5); se regenera al cambiar un valor, nunca se escribe a mano.
    /// </summary>
    private string ExplicacionEnPalabras => ExplicadorEnPalabras.ExplicarRafagaDistribuida(
        _umbralCanales, _ventanaDeteccion, _ventanaAntirrebote, _paramSimulacion);

    /// <summary>
    /// Confirma la propuesta tras validar contra los descriptores (human-in-the-loop, §6): la UI
    /// propone, el humano confirma, el sistema valida. La persistencia del calibrado vive fuera de
    /// esta rebanada; aquí se valida y se previsualiza, dejando la política en el modo elegido.
    /// </summary>
    private void ConfirmarParametros()
    {
        if (!ParametrosValidos)
        {
            Snackbar.Add("Hay valores fuera de los límites del descriptor; corregí antes de confirmar (RN-10).", Severity.Error);
            return;
        }

        var modo = _paramSimulacion ? "simulación" : "ejecución real";
        Snackbar.Add($"Configuración validada contra los descriptores y aplicada en {modo} (CU-11, RN-10).", Severity.Success);
    }

    protected override async Task OnInitializedAsync()
    {
        _servidores = await RepositorioServidores.ListarAsync();
        if (_servidores.Count > 0)
        {
            await CambiarServidorAsync(_servidores[0].SnowflakeServidor.Valor);
        }
    }

    private async Task CambiarServidorAsync(string servidorId)
    {
        _servidorId = servidorId;
        await RecargarAsync();
    }

    private async Task RecargarAsync()
    {
        if (_servidorId is null)
        {
            return;
        }

        var sid = new Snowflake(_servidorId);
        _grupos = await ServicioConfiguracion.ListarGruposAsync(sid);
        _eventos = await ServicioConfiguracion.ListarEventosAsync(sid);

        var reglas = await ServicioConfiguracion.ListarReglasContenidoAsync(sid);
        _reglasDisponibles = reglas.Select(r => new ReglaItem(r.Id, r.Nombre)).ToList();
    }

    private async Task GuardarReglaAsync()
    {
        if (_servidorId is null) return;
        _procesando = true;
        var resultado = await ServicioReglas.RegistrarPorExpresionRegularAsync(
            new Snowflake(_servidorId), _grupoNombre is "" ? "Política" : _grupoNombre, _reglaNombre, _reglaPatron);
        if (resultado.Exito)
        {
            Snackbar.Add("Regla guardada (validada al guardar, RN-03).", Severity.Success);
            _reglaNombre = _reglaPatron = string.Empty;
            await RecargarAsync();
        }
        else
        {
            Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", Severity.Error);
        }
        _procesando = false;
    }

    private void AlternarRegla(int id, bool incluir)
    {
        if (incluir) _reglasSeleccionadas.Add(id); else _reglasSeleccionadas.Remove(id);
    }

    private void AlternarGrupoEvento(int id, bool incluir)
    {
        if (incluir) _gruposEventoSeleccionados.Add(id); else _gruposEventoSeleccionados.Remove(id);
    }

    private async Task GuardarGrupoAsync()
    {
        if (_servidorId is null) return;
        _procesando = true;

        // Reglas evaluables (para validar la composición con el dominio) y su contraparte persistible.
        var evaluables = new List<IReglaEvaluable>();
        var persistencia = new List<ReglaDeGrupo>();
        foreach (var id in _reglasSeleccionadas)
        {
            var item = _reglasDisponibles.First(r => r.Id == id);
            persistencia.Add(new ReglaDeGrupo("contenido", id, null));
            // Para la validación de composición alcanza con un evaluable; el motor recompone al evaluar.
            evaluables.Add(new ReglaEvaluableContenido(
                DiscordModeradorBot.Servicio.Dominio.Contenido.ReglaContenido.PorExpresionRegular(
                    item.Nombre, ".*", DiscordModeradorBot.Servicio.Dominio.Contenido.EvaluadorReglaContenido.TopeTiempoPorDefecto),
                new DiscordModeradorBot.Servicio.Dominio.Contenido.EvaluadorReglaContenido()));
        }
        if (_incluirConducta)
        {
            persistencia.Add(new ReglaDeGrupo("conducta", null, "rafaga-distribuida"));
            evaluables.Add(new ReglaEvaluableConducta(
                new DiscordModeradorBot.Servicio.Dominio.Conducta.EvaluadorRafagaDistribuida()));
        }

        int? n = _grupoModo == ModoCoincidencia.AlMenosN ? _grupoN : null;
        var resultado = await ServicioConfiguracion.GuardarGrupoAsync(
            new Snowflake(_servidorId), _grupoNombre, _grupoModo, evaluables, persistencia, n);

        if (resultado.Exito)
        {
            Snackbar.Add("Grupo guardado (composición válida, RN-15).", Severity.Success);
            _grupoNombre = string.Empty;
            _reglasSeleccionadas.Clear();
            _incluirConducta = false;
            await RecargarAsync();
        }
        else
        {
            Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", Severity.Error);
        }
        _procesando = false;
    }

    private async Task EliminarGrupoAsync(int grupoId)
    {
        _procesando = true;
        var resultado = await ServicioConfiguracion.EliminarGrupoAsync(grupoId);
        Snackbar.Add(
            resultado.Exito ? "Grupo eliminado." : $"{resultado.Codigo}: {resultado.Mensaje}",
            resultado.Exito ? Severity.Success : Severity.Warning);
        await RecargarAsync();
        _procesando = false;
    }

    private async Task GuardarEventoAsync()
    {
        if (_servidorId is null) return;
        _procesando = true;
        var resultado = await ServicioConfiguracion.GuardarEventoAsync(
            new Snowflake(_servidorId), _eventoNombre, _eventoPrioridad, continuar: false,
            modo: _eventoSimulacion ? "simulacion" : "ejecucion", modoCombinacionGrupos: "todos",
            gruposIds: _gruposEventoSeleccionados.ToList(),
            acciones: new[]
            {
                new AccionPersistida("ReportarACanalPrivado", 0, null, null, null),
                new AccionPersistida("BaneoConBorradoRetroactivo", 1, 1, null, null),
            });

        if (resultado.Exito)
        {
            Snackbar.Add("Evento guardado (RN-04, RN-05).", Severity.Success);
            _eventoNombre = string.Empty;
            _gruposEventoSeleccionados.Clear();
            await RecargarAsync();
        }
        else
        {
            Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", Severity.Error);
        }
        _procesando = false;
    }
}

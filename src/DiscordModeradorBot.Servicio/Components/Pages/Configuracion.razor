@page "/configuracion"
@using DiscordModeradorBot.Servicio.Aplicacion
@using DiscordModeradorBot.Servicio.Aplicacion.Puertos
@using DiscordModeradorBot.Servicio.Dominio
@using DiscordModeradorBot.Servicio.Dominio.Configuracion
@using DiscordModeradorBot.Servicio.Dominio.Contenido
@using DiscordModeradorBot.Servicio.Dominio.Moderacion
@using DiscordModeradorBot.Servicio.Dominio.Moderacion.Reglas
@attribute [Authorize]
@rendermode InteractiveServer
@inject ServicioConfiguracionModeracion ServicioConfiguracion
@inject ServicioRegistroReglaContenido ServicioReglas
@inject IRepositorioServidores RepositorioServidores
@inject ISnackbar Snackbar
@inject IDialogService DialogService

@* Administración de la configuración de moderación dirigida por descriptores (CU-11, RN-10,
   ADR-12). Solo el administrador autenticado ([Authorize], RN-12). Permite administrar reglas de
   contenido, grupos de reglas con su modo de coincidencia (RN-15) y eventos/políticas con sus
   grupos y prioridad (RN-04). Cada parámetro configurable se renderiza desde su DescriptorParametro
   (etiqueta, leyenda, default, límites, ejemplos) con ayuda contextual; la validación toma los
   límites del descriptor (no hardcodea). La UI propone, el humano confirma, el sistema valida; la
   ranura del asistente de IA queda reservada y deshabilitada (forward-compat, no se construye). *@

<PageTitle>Configuración de moderación</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Configuración de moderación</MudText>
<MudText Class="mb-4">
    Reglas, grupos y eventos dirigidos por descriptores: cada parámetro toma su valor por defecto,
    sus límites y su ayuda del descriptor único (RN-10, ADR-12).
</MudText>

@if (_servidores is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else if (_servidores.Count == 0)
{
    <MudAlert Severity="Severity.Info">
        No hay servidores registrados. Registrá un servidor antes de configurar la moderación
        (<MudLink Href="/servidores">Registro y prueba</MudLink>).
    </MudAlert>
}
else
{
    <MudSelect T="string" Label="Servidor" Value="_servidorId" ValueChanged="CambiarServidorAsync"
               Class="mb-4" Dense="true">
        @foreach (var servidor in _servidores)
        {
            <MudSelectItem T="string" Value="@servidor.SnowflakeServidor.Valor">
                @(servidor.NombreDescriptivo ?? servidor.SnowflakeServidor.Valor)
            </MudSelectItem>
        }
    </MudSelect>

    @if (_servidorId is not null)
    {
        <MudTabs Elevation="1" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4">

            @* ---- Reglas (asistente multi-categoría) ---- *@
            <MudTabPanel Text="Reglas">
                @* Asistente de alta en 3 pasos —(1) categoría, (2) datos, (3) confirmar— que cubre
                   las clases de regla del modelo (CU-04, TipoCriterioContenido): contenido por
                   expresión regular, contenido por palabras clave y la regla de conducta incorporada
                   (ráfaga distribuida), que se calibra en Parámetros y se usa al armar un grupo. *@
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-1">Nueva regla</MudText>
                    <MudText Typo="Typo.caption" Class="mb-3 d-block mud-text-secondary">Paso @_reglaPaso de 3</MudText>

                    @if (_reglaPaso == 1)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">¿Qué tipo de regla querés agregar?</MudText>
                        <MudRadioGroup T="CategoriaRegla" Value="_reglaCategoria" ValueChanged="@(c => _reglaCategoria = c)">
                            <MudRadio T="CategoriaRegla" Value="CategoriaRegla.ContenidoRegex" Dense="true">
                                Contenido · expresión regular
                                <MudText Typo="Typo.caption" Class="d-block mud-text-secondary">Coincide el texto del mensaje contra un patrón regex.</MudText>
                            </MudRadio>
                            <MudRadio T="CategoriaRegla" Value="CategoriaRegla.ContenidoPalabras" Dense="true">
                                Contenido · palabras clave
                                <MudText Typo="Typo.caption" Class="d-block mud-text-secondary">Coincide si el mensaje contiene alguna de las palabras o frases.</MudText>
                            </MudRadio>
                            <MudRadio T="CategoriaRegla" Value="CategoriaRegla.ConductaRafaga" Dense="true">
                                Conducta · ráfaga distribuida (incorporada)
                                <MudText Typo="Typo.caption" Class="d-block mud-text-secondary">Mismo usuario publicando en varios canales dentro de una ventana; se calibra en Parámetros.</MudText>
                            </MudRadio>
                        </MudRadioGroup>
                        <div class="d-flex justify-end mt-3">
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="@(() => _reglaPaso = 2)">Siguiente</MudButton>
                        </div>
                    }
                    else if (_reglaPaso == 2)
                    {
                        @if (_reglaCategoria == CategoriaRegla.ContenidoRegex)
                        {
                            <MudTextField @bind-Value="_reglaNombre" Label="Nombre" Class="mb-2" />
                            <MudTextField @bind-Value="_reglaPatron" Label="Patrón (expresión regular)"
                                          HelperText="Se valida al guardar (RN-03)." Class="mb-2" />
                            <MudCheckBox T="bool" @bind-Value="_reglaSensible" Label="Distinguir mayúsculas/minúsculas" Dense="true" />
                        }
                        else if (_reglaCategoria == CategoriaRegla.ContenidoPalabras)
                        {
                            <MudTextField @bind-Value="_reglaNombre" Label="Nombre" Class="mb-2" />
                            <MudTextField @bind-Value="_reglaPalabras" Label="Palabras o frases clave" Lines="4"
                                          HelperText="Una por línea o separadas por coma. Coincide si el mensaje contiene alguna."
                                          Class="mb-2" />
                            <MudCheckBox T="bool" @bind-Value="_reglaSensible" Label="Distinguir mayúsculas/minúsculas" Dense="true" />
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-2">
                                La <b>ráfaga distribuida</b> es una regla de conducta <b>incorporada</b>: detecta al mismo
                                usuario publicando en varios canales dentro de una ventana. No se crea como fila; se
                                <b>calibra</b> en la pestaña <b>Parámetros</b> y se <b>usa</b> marcándola al armar un <b>Grupo</b>.
                            </MudAlert>
                            <MudText Typo="Typo.body2">
                                Umbral actual: ≥ @_umbralCanales canales en @_ventanaDeteccion s (antirrebote @_ventanaAntirrebote s).
                            </MudText>
                        }
                        <div class="d-flex justify-space-between mt-3">
                            <MudButton Variant="Variant.Text" OnClick="@(() => _reglaPaso = 1)">Atrás</MudButton>
                            <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="@(() => _reglaPaso = 3)">Siguiente</MudButton>
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.subtitle2" Class="mb-2">Confirmá la regla</MudText>
                        @if (_reglaCategoria == CategoriaRegla.ConductaRafaga)
                        {
                            <MudText Typo="Typo.body2" Class="mb-1">Tipo: Conducta · ráfaga distribuida (incorporada).</MudText>
                            <MudText Typo="Typo.body2">No se crea una fila: calibrá sus parámetros en <b>Parámetros</b> y agregala en un <b>Grupo</b>.</MudText>
                            <div class="d-flex justify-space-between mt-3">
                                <MudButton Variant="Variant.Text" OnClick="@(() => _reglaPaso = 2)">Atrás</MudButton>
                                <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="@(() => _reglaPaso = 1)">Entendido</MudButton>
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Class="mb-1">Tipo: @TipoReglaAmigable(_reglaCategoria == CategoriaRegla.ContenidoPalabras ? nameof(TipoCriterioContenido.PalabrasClave) : nameof(TipoCriterioContenido.ExpresionRegular))</MudText>
                            <MudText Typo="Typo.body2" Class="mb-1">Nombre: @(_reglaNombre is "" ? "(sin nombre)" : _reglaNombre)</MudText>
                            <MudText Typo="Typo.body2">
                                @(_reglaCategoria == CategoriaRegla.ContenidoPalabras ? "Palabras: " : "Patrón: ")
                                @(_reglaCategoria == CategoriaRegla.ContenidoPalabras
                                    ? (_reglaPalabras is "" ? "(vacío)" : _reglaPalabras.Replace("\n", ", "))
                                    : (_reglaPatron is "" ? "(vacío)" : _reglaPatron))
                            </MudText>
                            <div class="d-flex justify-space-between mt-3">
                                <MudButton Variant="Variant.Text" OnClick="@(() => _reglaPaso = 2)">Atrás</MudButton>
                                <MudButton Color="Color.Primary" Variant="Variant.Filled"
                                           OnClick="ConfirmarReglaAsync" Disabled="_procesando">Crear regla</MudButton>
                            </div>
                        }
                    }
                </MudPaper>

                <MudText Typo="Typo.subtitle1" Class="mb-2">Reglas del servidor</MudText>
                <MudTable Items="FilasReglas" Hover="true" Dense="true" T="FilaRegla">
                    <HeaderContent>
                        <MudTh>Nombre</MudTh><MudTh>Tipo</MudTh><MudTh>Detalle</MudTh><MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Nombre">@context.Nombre</MudTd>
                        <MudTd DataLabel="Tipo">@context.Tipo</MudTd>
                        <MudTd DataLabel="Detalle">@context.Detalle</MudTd>
                        <MudTd>
                            @if (context.EsIncorporada)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Default">incorporada</MudChip>
                            }
                            else
                            {
                                <MudButton Color="Color.Primary" Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => EditarReglaAsync(context.Id))" Disabled="_procesando">
                                    Editar
                                </MudButton>
                                <MudButton Color="Color.Error" Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => EliminarReglaAsync(context.Id))" Disabled="_procesando">
                                    Eliminar
                                </MudButton>
                            }
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudTabPanel>

            @* ---- Grupos de reglas ---- *@
            <MudTabPanel Text="Grupos">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">@(_grupoEnEdicion is null ? "Nuevo grupo de reglas" : "Editar grupo")</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_grupoNombre" Label="Nombre" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="ModoCoincidencia" @bind-Value="_grupoModo" Label="Modo de coincidencia"
                                       HelperText="Cómo se combinan las reglas del grupo (RN-15).">
                                <MudSelectItem T="ModoCoincidencia" Value="ModoCoincidencia.Todas">Todas las reglas coinciden</MudSelectItem>
                                <MudSelectItem T="ModoCoincidencia" Value="ModoCoincidencia.Alguna">Al menos una coincide</MudSelectItem>
                                <MudSelectItem T="ModoCoincidencia" Value="ModoCoincidencia.AlMenosN">Al menos N coinciden</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        @if (_grupoModo == ModoCoincidencia.AlMenosN)
                        {
                            <MudItem xs="12" sm="4">
                                <MudNumericField T="int" @bind-Value="_grupoN" Label="N mínimo" Min="1" />
                            </MudItem>
                        }
                    </MudGrid>
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Reglas del grupo</MudText>
                    @if (_reglasContenido.Count == 0)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-1">
                            No hay reglas de contenido. Podés armar el grupo solo con la ráfaga distribuida
                            (abajo), o crear reglas de contenido en la pestaña «Reglas».
                        </MudAlert>
                    }
                    else
                    {
                        @foreach (var regla in _reglasContenido)
                        {
                            <MudCheckBox T="bool" Value="@_reglasSeleccionadas.Contains(regla.Id)"
                                         ValueChanged="@(v => AlternarRegla(regla.Id, v))"
                                         Label="@($"{regla.Nombre} — {TipoReglaAmigable(regla.TipoCriterio)}")" Dense="true" />
                        }
                    }
                    @* La ráfaga distribuida es una regla de conducta INCORPORADA: está siempre disponible,
                       haya o no reglas de contenido. Un grupo puede componerse solo con ella (RC-04). *@
                    <MudCheckBox T="bool" Value="_incluirConducta"
                                 ValueChanged="@(v => _incluirConducta = v)"
                                 Label="Ráfaga distribuida (conducta)" Dense="true" />
                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mt-2"
                               OnClick="GuardarGrupoAsync" Disabled="_procesando">
                        @(_grupoEnEdicion is null ? "Guardar grupo" : "Actualizar grupo")
                    </MudButton>
                    @if (_grupoEnEdicion is not null)
                    {
                        <MudButton Variant="Variant.Text" Class="mt-2 ml-1"
                                   OnClick="CancelarEdicionGrupo" Disabled="_procesando">Cancelar</MudButton>
                    }
                </MudPaper>

                @if (_grupos is not null && _grupos.Count > 0)
                {
                    <MudTable Items="_grupos" Hover="true" Dense="true" T="GrupoPersistido">
                        <HeaderContent>
                            <MudTh>Nombre</MudTh><MudTh>Modo</MudTh><MudTh>Reglas</MudTh><MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Nombre">@context.Nombre</MudTd>
                            <MudTd DataLabel="Modo">@context.ModoCoincidencia @(context.MinimoCoincidencias is { } n ? $"({n})" : "")</MudTd>
                            <MudTd DataLabel="Reglas">@context.Reglas.Count</MudTd>
                            <MudTd>
                                <MudButton Color="Color.Primary" Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => EditarGrupoCargar(context))" Disabled="_procesando">
                                    Editar
                                </MudButton>
                                <MudButton Color="Color.Error" Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => EliminarGrupoAsync(context.Id))" Disabled="_procesando">
                                    Eliminar
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            @* ---- Eventos / políticas ---- *@
            <MudTabPanel Text="Eventos">
                <MudPaper Class="pa-4 mb-4">
                    <MudText Typo="Typo.h6" Class="mb-2">@(_eventoEnEdicion is null ? "Nuevo evento" : "Editar evento")</MudText>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_eventoNombre" Label="Nombre" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudNumericField T="int" @bind-Value="_eventoPrioridad" Label="Prioridad"
                                             HelperText="Menor = mayor prioridad (RN-04)." />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="bool" @bind-Value="_eventoSimulacion" Label="Modo">
                                <MudSelectItem T="bool" Value="true">Simulación</MudSelectItem>
                                <MudSelectItem T="bool" Value="false">Ejecución real</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                    @if (_eventoSimulacion)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="mt-2">Modo simulación</MudChip>
                    }
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Grupos del evento</MudText>
                    @if (_grupos is null || _grupos.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true">Creá al menos un grupo (RN-15).</MudAlert>
                    }
                    else
                    {
                        @foreach (var grupo in _grupos)
                        {
                            <MudCheckBox T="bool" Value="@_gruposEventoSeleccionados.Contains(grupo.Id)"
                                         ValueChanged="@(v => AlternarGrupoEvento(grupo.Id, v))"
                                         Label="@grupo.Nombre" Dense="true" />
                        }
                    }

                    @* ---- C: modo de combinación de los grupos del evento (RN-15) ---- *@
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Combinación de grupos</MudText>
                    <MudSelect T="ModoCombinacionGrupos" @bind-Value="_eventoModoCombinacion"
                               Label="¿Cuándo dispara el evento?"
                               HelperText="Todos = deben coincidir todos los grupos; Alguno = alcanza con que coincida uno (RN-15).">
                        <MudSelectItem T="ModoCombinacionGrupos" Value="ModoCombinacionGrupos.Todos">Todos los grupos coinciden</MudSelectItem>
                        <MudSelectItem T="ModoCombinacionGrupos" Value="ModoCombinacionGrupos.Alguno">Alguno de los grupos coincide</MudSelectItem>
                    </MudSelect>

                    @* ---- B: acciones del evento, en orden de ejecución (RN-05) ---- *@
                    <MudText Typo="Typo.subtitle2" Class="mt-3 mb-1">Acciones a ejecutar (en orden, RN-05)</MudText>
                    @if (_accionesEvento.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">Agregá al menos una acción.</MudAlert>
                    }
                    else
                    {
                        @for (var i = 0; i < _accionesEvento.Count; i++)
                        {
                            var accion = _accionesEvento[i];
                            var indice = i;
                            <MudPaper Class="pa-2 mb-2" Outlined="true">
                                <MudGrid>
                                    <MudItem xs="2" sm="1" Class="d-flex align-center">
                                        <MudText Typo="Typo.body2">#@(indice + 1)</MudText>
                                    </MudItem>
                                    <MudItem xs="10" sm="5">
                                        <MudSelect T="TipoAccion" @bind-Value="accion.Tipo" Label="Acción" Dense="true">
                                            @foreach (var disponible in AccionesDisponibles)
                                            {
                                                <MudSelectItem T="TipoAccion" Value="disponible.Tipo">@disponible.Etiqueta</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </MudItem>
                                    <MudItem xs="8" sm="4">
                                        @if (accion.Tipo is TipoAccion.BaneoConBorradoRetroactivo or TipoAccion.Banear)
                                        {
                                            <MudNumericField T="int" @bind-Value="accion.VentanaBorradoDias" Min="0" Max="7"
                                                             Label="Días de borrado" Margin="Margin.Dense"
                                                             HelperText="Mensajes a purgar al banear (0-7, RN-02)." />
                                        }
                                        else if (accion.Tipo is TipoAccion.Timeout)
                                        {
                                            <MudNumericField T="int" @bind-Value="accion.DuracionTimeoutMinutos" Min="1"
                                                             Label="Minutos de silencio" Margin="Margin.Dense" />
                                        }
                                        else if (accion.Tipo is TipoAccion.AsignarRol or TipoAccion.QuitarRol)
                                        {
                                            <MudTextField @bind-Value="accion.RolObjetivo" Label="ID del rol"
                                                          Margin="Margin.Dense" HelperText="Snowflake del rol objetivo." />
                                        }
                                    </MudItem>
                                    <MudItem xs="4" sm="2" Class="d-flex align-center justify-end">
                                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                                       Disabled="@(indice == 0)" OnClick="@(() => SubirAccion(indice))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                                       Disabled="@(indice == _accionesEvento.Count - 1)" OnClick="@(() => BajarAccion(indice))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(() => QuitarAccion(indice))" />
                                    </MudItem>
                                </MudGrid>
                            </MudPaper>
                        }
                    }
                    <MudButton Variant="Variant.Outlined" Size="Size.Small" StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AgregarAccion" Class="mb-2 d-block">Agregar acción</MudButton>

                    <MudButton Color="Color.Primary" Variant="Variant.Filled" Class="mt-2"
                               OnClick="GuardarEventoAsync" Disabled="_procesando">
                        @(_eventoEnEdicion is null ? "Guardar evento" : "Actualizar evento")
                    </MudButton>
                    @if (_eventoEnEdicion is not null)
                    {
                        <MudButton Variant="Variant.Text" Class="mt-2 ml-1"
                                   OnClick="CancelarEdicionEvento" Disabled="_procesando">Cancelar</MudButton>
                    }
                </MudPaper>

                @if (_eventos is not null && _eventos.Count > 0)
                {
                    <MudTable Items="_eventos" Hover="true" Dense="true" T="EventoPersistido">
                        <HeaderContent>
                            <MudTh>Nombre</MudTh><MudTh>Prioridad</MudTh><MudTh>Modo</MudTh><MudTh>Combinación</MudTh><MudTh>Grupos</MudTh><MudTh>Acciones</MudTh><MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Nombre">@context.Nombre</MudTd>
                            <MudTd DataLabel="Prioridad">@context.Prioridad</MudTd>
                            <MudTd DataLabel="Modo">@context.Modo</MudTd>
                            <MudTd DataLabel="Combinación">@context.ModoCombinacionGrupos</MudTd>
                            <MudTd DataLabel="Grupos">@context.GruposIds.Count</MudTd>
                            <MudTd DataLabel="Acciones">@context.Acciones.Count</MudTd>
                            <MudTd>
                                <MudButton Color="Color.Primary" Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => EditarEventoCargar(context))" Disabled="_procesando">
                                    Editar
                                </MudButton>
                                <MudButton Color="Color.Error" Size="Size.Small" Variant="Variant.Text"
                                           OnClick="@(() => EliminarEventoAsync(context.Id))" Disabled="_procesando">
                                    Eliminar
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudTabPanel>

            @* ---- Parámetros dirigidos por descriptor (RN-10, ADR-12, design-rules-config-esquema) ---- *@
            <MudTabPanel Text="Parámetros">
                <div class="d-flex align-center justify-space-between flex-wrap ga-2 mb-2">
                    <MudText Typo="Typo.h6">Parámetros de detección dirigidos por descriptor</MudText>
                    @* Indicador de modo simulación (§4.6): color + etiqueta, nunca solo color. *@
                    @if (_paramSimulacion)
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small"
                                 Icon="@Icons.Material.Filled.Science">Modo simulación</MudChip>
                    }
                </div>
                <MudText Class="mb-3">
                    Cada campo toma su etiqueta, su valor por defecto, sus límites y su ayuda del
                    descriptor único; la validación usa esos límites (RN-10, ADR-12). La UI propone, el
                    humano confirma, el sistema valida.
                </MudText>

                @* Presets / recetas (§4.4): cargan un conjunto de valores sugeridos del descriptor; no
                   se aplican directo, aterrizan en simulación para previsualizar antes de confirmar. *@
                <MudText Typo="Typo.subtitle2" Class="mb-1">Presets sugeridos</MudText>
                <div class="d-flex flex-wrap ga-2 mb-3">
                    @foreach (var preset in _presets)
                    {
                        <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Tune"
                                   OnClick="@(() => AplicarPreset(preset))">@preset.Nombre</MudButton>
                    }
                </div>

                @* Campo numérico dirigido por descriptor (§4.1): valor inicial = default; hint con
                   default y límites; validación inline desde los límites; ayuda contextual asociada. *@
                <MudNumericField T="int" Label="@RegistroDescriptores.UmbralCanalesDistintos.Etiqueta"
                                 @bind-Value="_umbralCanales"
                                 Min="@RegistroDescriptores.UmbralCanalesDistintos.Minimo"
                                 Max="@RegistroDescriptores.UmbralCanalesDistintos.Maximo"
                                 Validation="@((Func<int, string?>)ValidarUmbralCanales)"
                                 HelperText="@HintDe(RegistroDescriptores.UmbralCanalesDistintos)"
                                 Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Info"
                                 OnAdornmentClick="@(() => AlternarAyuda(RegistroDescriptores.UmbralCanalesDistintos.Clave))"
                                 aria-describedby="ayuda-umbral-canales-distintos"
                                 Class="mb-1" />
                @if (_ayudaAbierta.Contains(RegistroDescriptores.UmbralCanalesDistintos.Clave))
                {
                    @AyudaContextual(RegistroDescriptores.UmbralCanalesDistintos)
                }

                <MudNumericField T="double" Label="@RegistroDescriptores.VentanaDeteccionSegundos.Etiqueta"
                                 @bind-Value="_ventanaDeteccion" Step="0.5"
                                 Min="@RegistroDescriptores.VentanaDeteccionSegundos.Minimo"
                                 Max="@RegistroDescriptores.VentanaDeteccionSegundos.Maximo"
                                 Validation="@((Func<double, string?>)ValidarVentanaDeteccion)"
                                 HelperText="@HintDe(RegistroDescriptores.VentanaDeteccionSegundos)"
                                 Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Info"
                                 OnAdornmentClick="@(() => AlternarAyuda(RegistroDescriptores.VentanaDeteccionSegundos.Clave))"
                                 aria-describedby="ayuda-ventana-deteccion"
                                 Class="mt-3 mb-1" />
                @if (_ayudaAbierta.Contains(RegistroDescriptores.VentanaDeteccionSegundos.Clave))
                {
                    @AyudaContextual(RegistroDescriptores.VentanaDeteccionSegundos)
                }

                <MudNumericField T="double" Label="@RegistroDescriptores.VentanaAntirreboteSegundos.Etiqueta"
                                 @bind-Value="_ventanaAntirrebote" Step="0.5"
                                 Min="@RegistroDescriptores.VentanaAntirreboteSegundos.Minimo"
                                 Max="@RegistroDescriptores.VentanaAntirreboteSegundos.Maximo"
                                 Validation="@((Func<double, string?>)ValidarVentanaAntirrebote)"
                                 HelperText="@HintDe(RegistroDescriptores.VentanaAntirreboteSegundos)"
                                 Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Info"
                                 OnAdornmentClick="@(() => AlternarAyuda(RegistroDescriptores.VentanaAntirreboteSegundos.Clave))"
                                 aria-describedby="ayuda-ventana-antirrebote"
                                 Class="mt-3 mb-1" />
                @if (_ayudaAbierta.Contains(RegistroDescriptores.VentanaAntirreboteSegundos.Clave))
                {
                    @AyudaContextual(RegistroDescriptores.VentanaAntirreboteSegundos)
                }

                @* Previsualización: explicación EN PALABRAS generada por ExplicadorEnPalabras a partir
                   de descriptores + valores (§4.5); se regenera al cambiar un valor, no se redacta a
                   mano. Es también el texto de previsualización de la propuesta antes de confirmar. *@
                <MudPaper Class="pa-3 my-4" Outlined="true" Style="border-left: 4px solid var(--mud-palette-primary);">
                    <MudText Typo="Typo.subtitle2" Class="mb-1">Explicación en palabras (previsualización)</MudText>
                    <MudText Typo="Typo.body2" id="explicacion-en-palabras">@ExplicacionEnPalabras</MudText>
                </MudPaper>

                @* Modo simulación + confirmación: la UI NO aplica directo (§6, human-in-the-loop). *@
                <MudSwitch T="bool" @bind-Value="_paramSimulacion" Color="Color.Warning"
                           Label="Dejar la política en modo simulación (no ejecuta acciones reales)" />
                <div class="mt-2">
                    <MudButton Color="Color.Primary" Variant="Variant.Filled"
                               StartIcon="@Icons.Material.Filled.Check"
                               OnClick="ConfirmarParametros" Disabled="@(_procesando || !ParametrosValidos)">
                        Confirmar configuración
                    </MudButton>
                </div>

                @* Ranura del asistente de IA, RESERVADA y deshabilitada (forward-compat, §4.7). *@
                <MudPaper Class="pa-4 mt-4" Outlined="true" Style="border-style: dashed;"
                          aria-disabled="true"
                          aria-label="Asistente de configuración con IA, deshabilitado, próximamente">
                    <div class="d-flex align-center ga-2">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Color="Color.Default" />
                        <MudText Typo="Typo.subtitle2">Asistente de configuración (IA)</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Disabled="true">próximamente</MudChip>
                    </div>
                    <MudText Typo="Typo.caption" Class="mt-1">
                        Próximamente: el asistente propondrá una configuración (una propuesta validable),
                        el humano la confirma y el sistema la valida contra los descriptores. Ranura
                        reservada; no disponible en esta versión.
                    </MudText>
                </MudPaper>
            </MudTabPanel>
        </MudTabs>
    }
}

@* Tarjeta de ayuda contextual (§4.2): título "¿qué es <parámetro>?", leyenda y ejemplos del
   descriptor (nunca escritos a mano). Se asocia al campo por id (aria-describedby) para que el lector
   de pantalla la anuncie con el control. Genérica sobre el tipo del descriptor (int/double). *@
@{
    RenderFragment AyudaContextual<T>(DescriptorParametro<T> d) where T : struct, IComparable<T> =>
        @<MudAlert Severity="Severity.Info" Dense="true" Class="mb-2" id="@($"ayuda-{d.Clave}")">
            <MudText Typo="Typo.subtitle2">¿Qué es @d.Etiqueta?</MudText>
            <MudText Typo="Typo.body2" Class="mb-1">@d.Leyenda</MudText>
            <MudText Typo="Typo.caption">
                Por defecto @d.ValorPorDefecto; entre @d.Minimo y @d.Maximo.
                Ejemplos: @string.Join(", ", d.Ejemplos.Select(e => e.ToString())).
            </MudText>
        </MudAlert>;
}

@code {
    /// <summary>Categorías de regla que ofrece el asistente, según las clases del modelo (CU-04).</summary>
    private enum CategoriaRegla { ContenidoRegex, ContenidoPalabras, ConductaRafaga }

    /// <summary>Fila de la tabla de reglas del servidor (contenido persistido + conducta incorporada).</summary>
    private sealed record FilaRegla(int Id, string Nombre, string Tipo, string Detalle, bool EsIncorporada);

    /// <summary>Preset/receta (§4.4): un conjunto coherente de valores sugeridos para los descriptores.</summary>
    private sealed record Preset(string Nombre, int UmbralCanales, double VentanaDeteccion, double VentanaAntirrebote);

    private IReadOnlyList<DiscordModeradorBot.Servicio.Dominio.Servidores.ServidorRegistrado>? _servidores;
    private string? _servidorId;
    private bool _procesando;

    // Reglas (asistente multi-categoría)
    private int _reglaPaso = 1;
    private CategoriaRegla _reglaCategoria = CategoriaRegla.ContenidoRegex;
    private string _reglaNombre = string.Empty;
    private string _reglaPatron = string.Empty;
    private string _reglaPalabras = string.Empty;
    private bool _reglaSensible;
    private IReadOnlyList<ReglaContenidoResumen> _reglasContenido = new List<ReglaContenidoResumen>();

    // Grupos
    private int? _grupoEnEdicion;
    private string _grupoNombre = string.Empty;
    private ModoCoincidencia _grupoModo = ModoCoincidencia.Alguna;
    private int _grupoN = 2;
    private readonly HashSet<int> _reglasSeleccionadas = new();
    private bool _incluirConducta;
    private IReadOnlyList<GrupoPersistido>? _grupos;

    // Eventos
    private int? _eventoEnEdicion;
    private string _eventoNombre = string.Empty;
    private int _eventoPrioridad;
    private bool _eventoSimulacion = true;
    private ModoCombinacionGrupos _eventoModoCombinacion = ModoCombinacionGrupos.Todos;
    private readonly HashSet<int> _gruposEventoSeleccionados = new();
    private List<AccionEditable> _accionesEvento = CrearAccionesPorDefecto();
    private IReadOnlyList<EventoPersistido>? _eventos;

    /// <summary>Catálogo de acciones que se pueden configurar en un evento (RN-05), con su etiqueta en español.</summary>
    private static readonly (TipoAccion Tipo, string Etiqueta)[] AccionesDisponibles =
    {
        (TipoAccion.ReportarACanalPrivado, "Reportar al canal privado"),
        (TipoAccion.BaneoConBorradoRetroactivo, "Banear (con borrado de mensajes)"),
        (TipoAccion.Banear, "Banear (sin borrado)"),
        (TipoAccion.Timeout, "Silenciar temporalmente (timeout)"),
        (TipoAccion.Expulsar, "Expulsar"),
        (TipoAccion.AsignarRol, "Asignar rol"),
        (TipoAccion.QuitarRol, "Quitar rol"),
    };

    /// <summary>Vista editable de una acción del evento en el formulario; se mapea a AccionPersistida al guardar.</summary>
    private sealed class AccionEditable
    {
        public TipoAccion Tipo { get; set; } = TipoAccion.ReportarACanalPrivado;
        public int VentanaBorradoDias { get; set; } = 1;
        public int DuracionTimeoutMinutos { get; set; } = 10;
        public string RolObjetivo { get; set; } = string.Empty;
    }

    /// <summary>Acciones por defecto de un evento nuevo: reportar y luego banear con borrado (RN-05).</summary>
    private static List<AccionEditable> CrearAccionesPorDefecto() => new()
    {
        new AccionEditable { Tipo = TipoAccion.ReportarACanalPrivado },
        new AccionEditable { Tipo = TipoAccion.BaneoConBorradoRetroactivo, VentanaBorradoDias = 1 },
    };

    private void AgregarAccion() => _accionesEvento.Add(new AccionEditable());

    private void QuitarAccion(int indice)
    {
        if (indice >= 0 && indice < _accionesEvento.Count)
        {
            _accionesEvento.RemoveAt(indice);
        }
    }

    private void SubirAccion(int indice)
    {
        if (indice > 0)
        {
            (_accionesEvento[indice - 1], _accionesEvento[indice]) =
                (_accionesEvento[indice], _accionesEvento[indice - 1]);
        }
    }

    private void BajarAccion(int indice)
    {
        if (indice < _accionesEvento.Count - 1)
        {
            (_accionesEvento[indice + 1], _accionesEvento[indice]) =
                (_accionesEvento[indice], _accionesEvento[indice + 1]);
        }
    }

    /// <summary>Mapea la acción editable a su forma persistida, llevando solo el parámetro que aplica a su tipo.</summary>
    private static AccionPersistida ADominioAccion(AccionEditable accion, int orden) => new(
        accion.Tipo.ToString(),
        OrdenEjecucion: orden,
        VentanaBorradoDias: accion.Tipo is TipoAccion.BaneoConBorradoRetroactivo or TipoAccion.Banear
            ? accion.VentanaBorradoDias
            : null,
        DuracionTimeoutMinutos: accion.Tipo is TipoAccion.Timeout
            ? accion.DuracionTimeoutMinutos
            : null,
        RolObjetivo: accion.Tipo is TipoAccion.AsignarRol or TipoAccion.QuitarRol
            ? (string.IsNullOrWhiteSpace(accion.RolObjetivo) ? null : accion.RolObjetivo.Trim())
            : null);

    // ---- Parámetros dirigidos por descriptor (CU-11, RN-10) ----
    // Valor inicial = el default del descriptor (NO hardcodeado en la pantalla; §1, anti-patrón §10).
    private int _umbralCanales = RegistroDescriptores.UmbralCanalesDistintos.ValorPorDefecto;
    private double _ventanaDeteccion = RegistroDescriptores.VentanaDeteccionSegundos.ValorPorDefecto;
    private double _ventanaAntirrebote = RegistroDescriptores.VentanaAntirreboteSegundos.ValorPorDefecto;
    private bool _paramSimulacion = true;
    private readonly HashSet<string> _ayudaAbierta = new();

    // Presets sugeridos: valores tomados de los ejemplos de cada descriptor (§4.4); no se hardcodean
    // a ojo, son combinaciones de los ejemplos declarados en el RegistroDescriptores.
    private readonly List<Preset> _presets = new()
    {
        new Preset("Sensible",
            RegistroDescriptores.UmbralCanalesDistintos.Ejemplos[0],
            RegistroDescriptores.VentanaDeteccionSegundos.Ejemplos[0],
            RegistroDescriptores.VentanaAntirreboteSegundos.Ejemplos[0]),
        new Preset("Equilibrado",
            RegistroDescriptores.UmbralCanalesDistintos.ValorPorDefecto,
            RegistroDescriptores.VentanaDeteccionSegundos.ValorPorDefecto,
            RegistroDescriptores.VentanaAntirreboteSegundos.ValorPorDefecto),
        new Preset("Tolerante",
            RegistroDescriptores.UmbralCanalesDistintos.Ejemplos[^1],
            RegistroDescriptores.VentanaDeteccionSegundos.Ejemplos[^1],
            RegistroDescriptores.VentanaAntirreboteSegundos.Ejemplos[^1]),
    };

    /// <summary>Hint del campo: default y límites del descriptor (§4.1), tomados, no escritos a mano.</summary>
    private static string HintDe<T>(DescriptorParametro<T> d) where T : struct, IComparable<T> =>
        $"Por defecto {d.ValorPorDefecto}; entre {d.Minimo} y {d.Maximo}.";

    /// <summary>Abre o cierra la ayuda contextual del campo (disclosure por teclado/ratón, §8).</summary>
    private void AlternarAyuda(string clave)
    {
        if (!_ayudaAbierta.Add(clave))
        {
            _ayudaAbierta.Remove(clave);
        }
    }

    /// <summary>Carga un preset en simulación: precarga los valores y deja la red de seguridad (§4.4).</summary>
    private void AplicarPreset(Preset preset)
    {
        _umbralCanales = preset.UmbralCanales;
        _ventanaDeteccion = preset.VentanaDeteccion;
        _ventanaAntirrebote = preset.VentanaAntirrebote;
        _paramSimulacion = true;
        Snackbar.Add($"Preset '{preset.Nombre}' cargado en simulación; previsualizá y confirmá.", Severity.Info);
    }

    // Validación inline DESDE los límites del descriptor (RN-10): el mensaje indica el rango admitido,
    // no solo "valor inválido" (§5, §8). No duplica reglas: usa el servicio de aplicación.
    private string? ValidarUmbralCanales(int valor)
    {
        var r = ServicioConfiguracionModeracion.ValidarEntero(RegistroDescriptores.UmbralCanalesDistintos, valor);
        return r.Valido ? null : r.Mensaje;
    }

    private string? ValidarVentanaDeteccion(double valor)
    {
        var r = ServicioConfiguracionModeracion.ValidarDecimal(RegistroDescriptores.VentanaDeteccionSegundos, valor);
        return r.Valido ? null : r.Mensaje;
    }

    private string? ValidarVentanaAntirrebote(double valor)
    {
        var r = ServicioConfiguracionModeracion.ValidarDecimal(RegistroDescriptores.VentanaAntirreboteSegundos, valor);
        return r.Valido ? null : r.Mensaje;
    }

    /// <summary>Todos los parámetros caen dentro de sus límites; condición para confirmar (§6).</summary>
    private bool ParametrosValidos =>
        RegistroDescriptores.UmbralCanalesDistintos.EsValido(_umbralCanales)
        && RegistroDescriptores.VentanaDeteccionSegundos.EsValido(_ventanaDeteccion)
        && RegistroDescriptores.VentanaAntirreboteSegundos.EsValido(_ventanaAntirrebote);

    /// <summary>
    /// Explicación EN PALABRAS de la configuración actual, generada por ExplicadorEnPalabras a partir
    /// de descriptores + valores (§4.5); se regenera al cambiar un valor, nunca se escribe a mano.
    /// </summary>
    private string ExplicacionEnPalabras => ExplicadorEnPalabras.ExplicarRafagaDistribuida(
        _umbralCanales, _ventanaDeteccion, _ventanaAntirrebote, _paramSimulacion);

    /// <summary>
    /// Confirma la propuesta tras validar contra los descriptores (human-in-the-loop, §6): la UI
    /// propone, el humano confirma, el sistema valida. La persistencia del calibrado vive fuera de
    /// esta rebanada; aquí se valida y se previsualiza, dejando la política en el modo elegido.
    /// </summary>
    private async Task ConfirmarParametros()
    {
        if (_servidorId is null)
        {
            Snackbar.Add("Elegí un servidor antes de guardar los parámetros.", Severity.Warning);
            return;
        }

        if (!ParametrosValidos)
        {
            Snackbar.Add("Hay valores fuera de los límites del descriptor; corregí antes de confirmar (RN-10).", Severity.Error);
            return;
        }

        _procesando = true;
        var resultado = await ServicioConfiguracion.GuardarParametrosAsync(
            new Snowflake(_servidorId), _umbralCanales, _ventanaDeteccion, _ventanaAntirrebote);
        _procesando = false;

        if (resultado.Exito)
        {
            // Los parámetros quedan persistidos por servidor y el motor los aplica en el próximo
            // mensaje (ráfaga CU-01, antirrebote CU-16). El switch de simulación es del preview de
            // eventos, no de estos parámetros.
            Snackbar.Add("Parámetros guardados; el motor los aplica desde el próximo mensaje (CU-11, RN-10).", Severity.Success);
        }
        else
        {
            Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", Severity.Error);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _servidores = await RepositorioServidores.ListarAsync();
        if (_servidores.Count > 0)
        {
            await CambiarServidorAsync(_servidores[0].SnowflakeServidor.Valor);
        }
    }

    private async Task CambiarServidorAsync(string servidorId)
    {
        _servidorId = servidorId;
        await RecargarAsync();
    }

    private async Task RecargarAsync()
    {
        if (_servidorId is null)
        {
            return;
        }

        var sid = new Snowflake(_servidorId);
        _grupos = await ServicioConfiguracion.ListarGruposAsync(sid);
        _eventos = await ServicioConfiguracion.ListarEventosAsync(sid);

        _reglasContenido = await ServicioConfiguracion.ListarReglasContenidoAsync(sid);

        // Parámetros persistidos del servidor (CU-11, RN-10): se cargan en los campos del panel; si
        // el servidor no tiene fila, el servicio devuelve los valores por defecto del descriptor.
        var parametros = await ServicioConfiguracion.ObtenerParametrosAsync(sid);
        _umbralCanales = parametros.UmbralCanalesDistintos;
        _ventanaDeteccion = parametros.VentanaDeteccionSegundos;
        _ventanaAntirrebote = parametros.VentanaAntirreboteSegundos;
    }

    /// <summary>Etiqueta amigable de la clase de criterio (CU-04, TipoCriterioContenido).</summary>
    private static string TipoReglaAmigable(string tipoCriterio) => tipoCriterio switch
    {
        nameof(TipoCriterioContenido.ExpresionRegular) => "Contenido · expresión regular",
        nameof(TipoCriterioContenido.PalabrasClave) => "Contenido · palabras clave",
        _ => "Contenido",
    };

    /// <summary>
    /// Filas de la tabla de reglas: las reglas de contenido persistidas más la regla de conducta
    /// incorporada (ráfaga distribuida), que no es una fila persistida sino un detector built-in.
    /// </summary>
    private IReadOnlyList<FilaRegla> FilasReglas
    {
        get
        {
            var filas = _reglasContenido
                .Select(r => new FilaRegla(
                    r.Id, r.Nombre, TipoReglaAmigable(r.TipoCriterio), r.Criterio.Replace("\n", ", "), false))
                .ToList();

            filas.Add(new FilaRegla(
                0, "Ráfaga distribuida", "Conducta · incorporada",
                $"≥ {_umbralCanales} canales en {_ventanaDeteccion} s", true));

            return filas;
        }
    }

    private async Task ConfirmarReglaAsync()
    {
        if (_servidorId is null) return;
        _procesando = true;
        try
        {
            // La regla se asocia a la política por su nombre lógico (mínimo de R3); en este
            // asistente se usa "Política" por defecto (antes tomaba por error el nombre del grupo).
            var resultado = _reglaCategoria == CategoriaRegla.ContenidoPalabras
                ? await ServicioReglas.RegistrarPorPalabrasClaveAsync(
                    new Snowflake(_servidorId), "Política", _reglaNombre, _reglaPalabras, _reglaSensible)
                : await ServicioReglas.RegistrarPorExpresionRegularAsync(
                    new Snowflake(_servidorId), "Política", _reglaNombre, _reglaPatron, _reglaSensible);

            if (resultado.Exito)
            {
                Snackbar.Add("Regla creada (validada al guardar, RN-03).", Severity.Success);
                _reglaNombre = _reglaPatron = _reglaPalabras = string.Empty;
                _reglaSensible = false;
                _reglaPaso = 1;
                await RecargarAsync();
            }
            else
            {
                Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo crear la regla: {ex.Message}", Severity.Error);
        }
        finally
        {
            _procesando = false;
        }
    }

    private async Task EditarReglaAsync(int reglaId)
    {
        var regla = _reglasContenido.FirstOrDefault(r => r.Id == reglaId);
        if (regla is null) return;

        var parametros = new DialogParameters<DialogoEditarRegla>
        {
            { x => x.ReglaId, regla.Id },
            { x => x.NombreActual, regla.Nombre },
            { x => x.TipoCriterio, regla.TipoCriterio },
            { x => x.CriterioActual, regla.Criterio },
            { x => x.SensibleActual, regla.SensibleAMayusculas },
        };
        var dialogo = await DialogService.ShowAsync<DialogoEditarRegla>("Editar regla", parametros);
        var resultado = await dialogo.Result;
        if (resultado is not null && !resultado.Canceled)
        {
            await RecargarAsync();
        }
    }

    private async Task EliminarReglaAsync(int reglaId)
    {
        _procesando = true;
        try
        {
            var resultado = await ServicioConfiguracion.EliminarReglaContenidoAsync(reglaId);
            Snackbar.Add(
                resultado.Exito ? "Regla eliminada." : $"{resultado.Codigo}: {resultado.Mensaje}",
                resultado.Exito ? Severity.Success : Severity.Warning);
            await RecargarAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo eliminar la regla: {ex.Message}", Severity.Error);
        }
        finally
        {
            _procesando = false;
        }
    }

    private void AlternarRegla(int id, bool incluir)
    {
        if (incluir) _reglasSeleccionadas.Add(id); else _reglasSeleccionadas.Remove(id);
    }

    private void AlternarGrupoEvento(int id, bool incluir)
    {
        if (incluir) _gruposEventoSeleccionados.Add(id); else _gruposEventoSeleccionados.Remove(id);
    }

    private async Task GuardarGrupoAsync()
    {
        if (_servidorId is null) return;

        // Un grupo necesita al menos una regla (RC-04): de contenido o la ráfaga incorporada.
        if (_reglasSeleccionadas.Count == 0 && !_incluirConducta)
        {
            Snackbar.Add(
                "Seleccioná al menos una regla para el grupo (de contenido o la ráfaga distribuida).",
                Severity.Warning);
            return;
        }

        _procesando = true;

        // Reglas evaluables (para validar la composición con el dominio) y su contraparte persistible.
        var evaluables = new List<IReglaEvaluable>();
        var persistencia = new List<ReglaDeGrupo>();
        foreach (var id in _reglasSeleccionadas)
        {
            var item = _reglasContenido.First(r => r.Id == id);
            persistencia.Add(new ReglaDeGrupo("contenido", id, null));
            // Para la validación de composición alcanza con un evaluable; el motor recompone al evaluar.
            evaluables.Add(new ReglaEvaluableContenido(
                DiscordModeradorBot.Servicio.Dominio.Contenido.ReglaContenido.PorExpresionRegular(
                    item.Nombre, ".*", DiscordModeradorBot.Servicio.Dominio.Contenido.EvaluadorReglaContenido.TopeTiempoPorDefecto),
                new DiscordModeradorBot.Servicio.Dominio.Contenido.EvaluadorReglaContenido()));
        }
        if (_incluirConducta)
        {
            persistencia.Add(new ReglaDeGrupo("conducta", null, "rafaga-distribuida"));
            evaluables.Add(new ReglaEvaluableConducta(
                new DiscordModeradorBot.Servicio.Dominio.Conducta.EvaluadorRafagaDistribuida()));
        }

        int? n = _grupoModo == ModoCoincidencia.AlMenosN ? _grupoN : null;
        var resultado = _grupoEnEdicion is null
            ? await ServicioConfiguracion.GuardarGrupoAsync(
                new Snowflake(_servidorId), _grupoNombre, _grupoModo, evaluables, persistencia, n)
            : await ServicioConfiguracion.ActualizarGrupoAsync(
                _grupoEnEdicion.Value, _grupoNombre, _grupoModo, evaluables, persistencia, n);

        if (resultado.Exito)
        {
            Snackbar.Add(
                _grupoEnEdicion is null
                    ? "Grupo guardado (composición válida, RN-15)."
                    : "Grupo actualizado (composición válida, RN-15).",
                Severity.Success);
            CancelarEdicionGrupo();
            await RecargarAsync();
        }
        else
        {
            Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", Severity.Error);
        }
        _procesando = false;
    }

    private void EditarGrupoCargar(GrupoPersistido grupo)
    {
        _grupoEnEdicion = grupo.Id;
        _grupoNombre = grupo.Nombre;
        _grupoModo = Enum.TryParse<ModoCoincidencia>(grupo.ModoCoincidencia, ignoreCase: true, out var m)
            ? m
            : ModoCoincidencia.Alguna;
        _grupoN = grupo.MinimoCoincidencias ?? 2;
        _reglasSeleccionadas.Clear();
        foreach (var r in grupo.Reglas.Where(r => r.ClaseRegla == "contenido" && r.ReglaContenidoId is not null))
        {
            _reglasSeleccionadas.Add(r.ReglaContenidoId!.Value);
        }
        _incluirConducta = grupo.Reglas.Any(r => r.ClaseRegla == "conducta");
    }

    private void CancelarEdicionGrupo()
    {
        _grupoEnEdicion = null;
        _grupoNombre = string.Empty;
        _reglasSeleccionadas.Clear();
        _incluirConducta = false;
    }

    private async Task EliminarGrupoAsync(int grupoId)
    {
        _procesando = true;
        var resultado = await ServicioConfiguracion.EliminarGrupoAsync(grupoId);
        Snackbar.Add(
            resultado.Exito ? "Grupo eliminado." : $"{resultado.Codigo}: {resultado.Mensaje}",
            resultado.Exito ? Severity.Success : Severity.Warning);
        await RecargarAsync();
        _procesando = false;
    }

    private async Task GuardarEventoAsync()
    {
        if (_servidorId is null) return;

        // Las acciones ahora se configuran en el formulario (B): tipo + parámetros + orden (RN-05).
        if (_accionesEvento.Count == 0)
        {
            Snackbar.Add("Agregá al menos una acción al evento (RN-05).", Severity.Warning);
            return;
        }

        // Un rol objetivo es obligatorio para asignar/quitar rol; sin él la acción no se podría ejecutar.
        if (_accionesEvento.Any(a => a.Tipo is TipoAccion.AsignarRol or TipoAccion.QuitarRol
                                     && string.IsNullOrWhiteSpace(a.RolObjetivo)))
        {
            Snackbar.Add("Indicá el ID del rol en las acciones de asignar/quitar rol.", Severity.Warning);
            return;
        }

        _procesando = true;

        // El orden de ejecución es la posición en la lista (RN-05); cada acción lleva solo el
        // parámetro que aplica a su tipo (días de borrado, minutos de timeout o rol objetivo).
        IReadOnlyList<AccionPersistida> acciones = _accionesEvento
            .Select((a, i) => ADominioAccion(a, i))
            .ToList();

        var modo = _eventoSimulacion ? "simulacion" : "ejecucion";
        // El modo de combinación de grupos se elige en el formulario (C); se persiste en minúsculas
        // ("todos"/"alguno") como espera el resto del flujo (CU-11, RN-15).
        var modoCombinacion = _eventoModoCombinacion.ToString().ToLowerInvariant();
        var grupos = _gruposEventoSeleccionados.ToList();
        var resultado = _eventoEnEdicion is null
            ? await ServicioConfiguracion.GuardarEventoAsync(
                new Snowflake(_servidorId), _eventoNombre, _eventoPrioridad, continuar: false,
                modo: modo, modoCombinacionGrupos: modoCombinacion, gruposIds: grupos, acciones: acciones)
            : await ServicioConfiguracion.ActualizarEventoAsync(
                _eventoEnEdicion.Value, _eventoNombre, _eventoPrioridad, continuar: false,
                modo: modo, modoCombinacionGrupos: modoCombinacion, gruposIds: grupos, acciones: acciones);

        if (resultado.Exito)
        {
            Snackbar.Add(
                _eventoEnEdicion is null ? "Evento guardado (RN-04, RN-05)." : "Evento actualizado (RN-04, RN-05).",
                Severity.Success);
            CancelarEdicionEvento();
            await RecargarAsync();
        }
        else
        {
            Snackbar.Add($"{resultado.Codigo}: {resultado.Mensaje}", Severity.Error);
        }
        _procesando = false;
    }

    private void EditarEventoCargar(EventoPersistido evento)
    {
        _eventoEnEdicion = evento.Id;
        _eventoNombre = evento.Nombre;
        _eventoPrioridad = evento.Prioridad;
        _eventoSimulacion = evento.Modo == "simulacion";
        _eventoModoCombinacion = Enum.TryParse<ModoCombinacionGrupos>(
            evento.ModoCombinacionGrupos, ignoreCase: true, out var mc) ? mc : ModoCombinacionGrupos.Todos;
        _accionesEvento = evento.Acciones
            .OrderBy(a => a.OrdenEjecucion)
            .Select(a => new AccionEditable
            {
                Tipo = Enum.TryParse<TipoAccion>(a.Tipo, ignoreCase: true, out var t)
                    ? t
                    : TipoAccion.ReportarACanalPrivado,
                VentanaBorradoDias = a.VentanaBorradoDias ?? 1,
                DuracionTimeoutMinutos = a.DuracionTimeoutMinutos ?? 10,
                RolObjetivo = a.RolObjetivo ?? string.Empty,
            })
            .ToList();
        if (_accionesEvento.Count == 0)
        {
            _accionesEvento = CrearAccionesPorDefecto();
        }
        _gruposEventoSeleccionados.Clear();
        foreach (var id in evento.GruposIds)
        {
            _gruposEventoSeleccionados.Add(id);
        }
    }

    private void CancelarEdicionEvento()
    {
        _eventoEnEdicion = null;
        _eventoNombre = string.Empty;
        _eventoPrioridad = 0;
        _eventoSimulacion = true;
        _eventoModoCombinacion = ModoCombinacionGrupos.Todos;
        _accionesEvento = CrearAccionesPorDefecto();
        _gruposEventoSeleccionados.Clear();
    }

    private async Task EliminarEventoAsync(int eventoId)
    {
        _procesando = true;
        try
        {
            var resultado = await ServicioConfiguracion.EliminarEventoAsync(eventoId);
            Snackbar.Add(
                resultado.Exito ? "Evento eliminado." : $"{resultado.Codigo}: {resultado.Mensaje}",
                resultado.Exito ? Severity.Success : Severity.Warning);
            await RecargarAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo eliminar el evento: {ex.Message}", Severity.Error);
        }
        finally
        {
            _procesando = false;
        }
    }
}

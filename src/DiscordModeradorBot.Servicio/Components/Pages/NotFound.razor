@page "/not-found"
@layout EmptyLayout

@* Página de "no encontrado" (servida en el 404 vía UseStatusCodePagesWithReExecute). Usa el
   EmptyLayout (SSR, sin chrome ni circuito) para no requerir interactividad en la re-ejecución del
   pipeline de estados; muestra una tarjeta centrada coherente con el tema y un acceso al panel. *@

<PageTitle>Página no encontrada</PageTitle>

<MudPaper Class="auth-card mx-auto mt-16 pa-8" Elevation="0" Outlined="true" MaxWidth="420px">
    <MudText Typo="Typo.h6" GutterBottom="true">Página no encontrada</MudText>
    <MudText Typo="Typo.body2" Class="mb-6">
        No encontramos lo que buscabas. Puede que el enlace haya cambiado o ya no exista.
    </MudText>
    <MudButton Href="/incidentes" Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Outlined.ArrowBack">
        Volver al panel
    </MudButton>
</MudPaper>
